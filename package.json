{
  "name": "extract-design-system",
  "version": "0.1.3",
  "description": "CLI for extracting design primitives from public websites and generating starter token files for the extract-design-system agent skill workflow.",
  "type": "module",
  "bin": {
    "extract-design-system": "dist/cli.js"
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "node -e \"import('node:fs').then(fs => fs.rmSync('dist', { recursive: true, force: true }))\" && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "design-system",
    "design-system-extraction",
    "design-tokens",
    "agent-skill",
    "skills.sh",
    "skills",
    "cli",
    "cursor",
    "codex",
    "dembrandt"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arvindrk/extract-design-system.git"
  },
  "homepage": "https://github.com/arvindrk/extract-design-system#readme",
  "bugs": {
    "url": "https://github.com/arvindrk/extract-design-system/issues"
  },
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.1",
    "dembrandt": "^0.7.0",
    "execa": "^9.6.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
