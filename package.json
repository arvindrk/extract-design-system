{
  "name": "extract-design-system",
  "version": "0.1.0",
  "description": "Extract design primitives from public websites and generate starter token files.",
  "type": "module",
  "bin": {
    "extract-design-system": "dist/cli.js"
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "node -e \"import('node:fs').then(fs => fs.rmSync('dist', { recursive: true, force: true }))\" && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "design-system",
    "design-tokens",
    "skills",
    "cli",
    "dembrandt"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.1",
    "dembrandt": "^0.7.0",
    "execa": "^9.6.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
